server:
  port: 8080

spring:
  data:
    redis:
      host: localhost
      port: 6379
      password: redis
  security:
    user:
      name: admin
      password: admin
  datasource:
    url: jdbc:postgresql://localhost:5432/db_delivery_orders
    username: postgres
    password: postgres

springdoc:
  api-docs:
    enabled: true
  swagger-ui:
    enabled: true
